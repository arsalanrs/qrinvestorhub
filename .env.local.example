NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Must match NEXT_PUBLIC_SUPABASE_URL project (Settings → API → service_role)
# Optional — run migrations: npm run db:apply
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# SUPABASE_DB_PASSWORD=your-database-password
OPENAI_API_KEY=sk-...
SHAPE_API_BASE_URL=https://api.setshape.com/v1
SHAPE_API_KEY=your-shape-api-key
LENDINGPAD_API_BASE_URL=https://api.lendingpad.com
LENDINGPAD_API_KEY=your-lp-api-key
ENABLE_SHAPE_SYNC=false
ENABLE_LENDINGPAD_SYNC=false
ENABLE_AI_SUMMARY=false
NEXT_PUBLIC_APP_URL=http://localhost:3003
INVESTOR_HUB_ADMIN_EMAIL=nikksmith@questrock.com
INVESTOR_HUB_ADMIN_PASSWORD=your-secure-admin-password

# Submission email — one-pager to Nikk on each apply (use Formspree OR Resend)
# Formspree: create a form at formspree.io → set recipient to nikksmith@questrock.com → paste endpoint URL
FORMSPREE_INVESTOR_SUBMISSION_URL=https://formspree.io/f/your-form-id
# Resend alternative (if you already use it elsewhere):
# RESEND_API_KEY=re_...
# INVESTOR_SUBMISSION_FROM_EMAIL=QuestRock Investor Hub <notifications@questrock.com>
INVESTOR_SUBMISSION_NOTIFY_EMAIL=nikksmith@questrock.com
