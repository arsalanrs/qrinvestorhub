NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Must match NEXT_PUBLIC_SUPABASE_URL project (Settings → API → service_role)
# Optional — run migrations: npm run db:apply
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# SUPABASE_DB_PASSWORD=your-database-password
OPENAI_API_KEY=sk-...
SHAPE_API_BASE_URL=https://api.setshape.com/v1
SHAPE_API_KEY=your-shape-api-key
LENDINGPAD_API_BASE_URL=https://api.lendingpad.com
LENDINGPAD_API_KEY=your-lp-api-key
# Leave false when Zapier syncs Shape (recommended)
ENABLE_SHAPE_SYNC=false
SHAPE_CRM_ID=20931
SHAPE_INVESTOR_HUB_SOURCE_ID=
# Or full post URL: SHAPE_INVESTOR_HUB_POST_LEAD_URL=https://secure-api.setshape.com/postlead/20931/YOUR_SOURCE_ID
ENABLE_LENDINGPAD_SYNC=false
ENABLE_AI_SUMMARY=false
ENABLE_PROPERTY_AI_IMAGES=false
NEXT_PUBLIC_APP_URL=http://localhost:3003
# Supabase Auth — add redirect URL in Supabase dashboard:
#   {NEXT_PUBLIC_APP_URL}/auth/callback
INVESTOR_HUB_ADMIN_EMAIL=nikksmith@questrock.com
INVESTOR_HUB_ADMIN_PASSWORD=your-secure-admin-password

# Loan amount → staff email routing (used in Zapier payload; Zap sends the emails)
INVESTOR_EMAIL_RAY=rconway@questrock.com
INVESTOR_EMAIL_NIKK=nikksmith@questrock.com
INVESTOR_EMAIL_BASTIAN=bastianjohnston@questrock.com
INVESTOR_EMAIL_CC_NIKK=nikksmith@questrock.com
INVESTOR_EMAIL_CC_JASON=jfriday@questrock.com

# Zapier — ONE Catch Hook for all post-submit automations (Shape + staff + customer emails)
# Create Zap: Webhooks by Zapier → Catch Hook, then use Paths for each action below
ZAPIER_INVESTOR_SUBMISSION_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/XXXXX/YYYYY/
# Optional shared secret (Zapier Filter: header X-QuestRock-Webhook-Secret equals this value)
# ZAPIER_WEBHOOK_SECRET=your-random-secret

# Optional: attach prior call transcript summary from Call Tracker Supabase
# INBOUND_SUPABASE_URL=https://jvukecwkkijoeazovtcp.supabase.co
# INBOUND_SUPABASE_SERVICE_ROLE_KEY=

